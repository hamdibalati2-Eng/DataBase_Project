			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
		</conditionalStyle>
	</style>
	<query language="SQL"><![CDATA[SELECT 
    u.user_id,
    u.user_name as full_name,
    u.user_role as position,
    CASE 
        WHEN u.user_role = 'HeadCoach' THEN CONCAT('Coach, Age: ', h.age, ', From: ', h.nationality)
        WHEN u.user_role = 'Doctor' THEN CONCAT('Dr. ', d.specialization, ', Age: ', d.age)
        WHEN u.user_role = 'Player' THEN CONCAT('Player, Jersey: #', p.jerseynumber, ', Position: ', p.position)
        WHEN u.user_role = 'Manager' THEN 'Management Staff'
        ELSE 'Staff Member'
    END as staff_details,
    CASE 
        WHEN u.user_role IN ('HeadCoach', 'Doctor', 'Manager') THEN 'Staff'
        WHEN u.user_role = 'Player' THEN 'Athlete'
        ELSE 'Other'
    END as employee_category,
    c.salary as annual_salary,
    CASE 
        WHEN c.salary >= 120000 THEN 'Senior Level'
        WHEN c.salary >= 90000 THEN 'Mid Level'
        ELSE 'Entry Level'
    END as salary_grade,
    DATE(c.start_date) as hire_date
FROM users u
LEFT JOIN headcoaches h ON u.user_id = h.coach_id
LEFT JOIN doctors d ON u.user_id = d.doctor_id
LEFT JOIN players p ON u.user_id = p.player_id
LEFT JOIN contract c ON u.user_id = c.user_id
ORDER BY u.user_role, c.salary DESC]]></query>
