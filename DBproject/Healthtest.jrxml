			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
		</conditionalStyle>
	</style>
	<query language="SQL"><![CDATA[SELECT 
    u.user_name as player_name,
    p.position,
    p.age,
    p.healthstatus,
    CASE 
        WHEN i.injury_id IS NOT NULL THEN 'Has Injury'
        ELSE 'Healthy'
    END as injury_status,
    i.injury_description,
    i.recovery_date
FROM users u
JOIN players p ON u.user_id = p.player_id
LEFT JOIN injuries i ON p.player_id = i.player_id
WHERE u.user_role = 'Player'
ORDER BY p.position]]></query>
