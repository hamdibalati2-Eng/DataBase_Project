			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
		</conditionalStyle>
	</style>
	<query language="SQL"><![CDATA[SELECT 
    u.user_role,
    COUNT(c.contract_id) as total_contracts,
    AVG(c.salary) as average_salary,
    MAX(c.salary) as highest_salary,
    MIN(c.salary) as lowest_salary
FROM users u
JOIN contract c ON u.user_id = c.user_id
GROUP BY u.user_role]]></query>
	<field name="user_role" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="user_role"/>
		<property name="com.jaspersoft.studio.field.label" value="user_role"/>
