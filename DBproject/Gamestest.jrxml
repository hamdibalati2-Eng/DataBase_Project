			<conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
		</conditionalStyle>
	</style>
	<query language="SQL"><![CDATA[SELECT 
    t.name as tournament_name,
    t.status as tournament_status,
    t.location as tournament_location,
    COUNT(g.game_id) as scheduled_games,
    g.tactics as game_strategy,
    g.stadium as venue,
    g.jersey_type as kit_type,
    DATE(g.match_date) as game_date,
    CASE 
        WHEN t.status = 'Upcoming' THEN 'Future Event'
        WHEN t.status = 'Ongoing' THEN 'Active Tournament'
        ELSE 'Past Event'
    END as event_classification
FROM tournaments t
LEFT JOIN gamesschedule g ON t.tournament_id = g.tournament_id
GROUP BY t.tournament_id, t.name, t.status, t.location, g.game_id, g.tactics, g.stadium, g.jersey_type, g.match_date
ORDER BY g.match_date]]></query>
